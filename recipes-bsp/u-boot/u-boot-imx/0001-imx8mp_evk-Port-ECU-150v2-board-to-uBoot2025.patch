+bootenvfile=uEnv.txt
+importbootenv=echo Importing environment from mmc${mmcdev} ...;
+        env import -t ${loadaddr} ${filesize}
+loadbootenv=load mmc ${mmcdev} ${loadaddr} ${bootenvfile}
+
 kernel_addr_r=CONFIG_SYS_LOAD_ADDR
-loadimage=fatload mmc ${mmcdev}:${mmcpart} ${loadaddr} ${image}
-loadfdt=fatload mmc ${mmcdev}:${mmcpart} ${fdt_addr_r} ${fdtfile}
+loadimage=load mmc ${mmcdev}:${mmcpart} ${loadaddr} ${image}
+loadfdt=load mmc ${mmcdev}:${mmcpart} ${fdt_addr_r} ${fdtfile}
 mmcboot=echo Booting from mmc ...;
+	if run loadbootenv; then
+		echo Loaded env from ${bootenvfile};
+		run importbootenv;
+	fi;
 	run mmcargs;
 	if test ${boot_fit} = yes || test ${boot_fit} = try; then
 		bootm ${loadaddr};
@@ -80,6 +91,20 @@ mmcboot=echo Booting from mmc ...;
 			echo WARN: Cannot load the DT;
 		fi;
 	fi;
+emmcboot=echo Booting from emmc ...;
+	setenv mmcdev 0;
+	setenv mmcroot /dev/mmcblk0p2 rootwait rw;
+	if run loadbootenv; then
+		echo Loaded env from ${bootenvfile};
+		run importbootenv;
+	fi;
+	run mmcargs;
+	mmc dev ${mmcdev};
+	if run loadimage; then
+		if run loadfdt; then
+			booti ${loadaddr} - ${fdt_addr_r};
+		fi;
+	fi;
 netargs=setenv bootargs ${jh_clk} ${mcore_clk} console=${console} root=/dev/nfs
 	ip=dhcp nfsroot=${serverip}:${nfsroot},v3,tcp
 netboot=echo Booting from net ...;
@@ -101,10 +126,12 @@ netboot=echo Booting from net ...;
 	fi;
 bsp_bootcmd=setenv opteeoverlay yes;echo Running BSP bootcmd ...;
 	mmc dev ${mmcdev};
-	if run loadimage; then
-		run mmcboot;
-	else
-		run netboot;
+	if mmc rescan; then
+		if run loadimage; then
+			run mmcboot;
+		else
+			run emmcboot;
+		fi;
 	fi;
 #endif
 #endif
