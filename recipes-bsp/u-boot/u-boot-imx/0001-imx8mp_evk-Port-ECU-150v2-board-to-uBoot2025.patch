 bootm_size=0x10000000
 console=ttymxc1,115200
 splashimage=0x50000000
-fdt_addr_r=0x43000000
-fdt_addr=0x43000000
+fdt_addr_r=0x48000000
+fdt_addr=0x48000000
 fdt_high=0xffffffffffffffff
 fdtfile=CONFIG_DEFAULT_FDT_FILE
 image=Image
@@ -64,12 +64,23 @@ mmcpart=1
