index 294049ff9d2..306c8377edd 100644
--- a/board/freescale/imx8mp_evk/imx8mp_evk.c
+++ b/board/freescale/imx8mp_evk/imx8mp_evk.c
@@ -29,11 +29,12 @@
 #include <dm/uclass-internal.h>
 #include <dm/pinctrl.h>
 #include <fuse.h>
+#include <i2c.h>
 #include <mmc.h>
 
 DECLARE_GLOBAL_DATA_PTR;
 
-#define UART_PAD_CTRL	(PAD_CTL_DSE6 | PAD_CTL_FSEL1)
+#define UART_PAD_CTRL	(PAD_CTL_DSE6 | PAD_CTL_FSEL1 | PAD_CTL_PUE)
 #define WDOG_PAD_CTRL	(PAD_CTL_DSE6 | PAD_CTL_ODE | PAD_CTL_PUE | PAD_CTL_PE)
 
 static iomux_v3_cfg_t const uart_pads[] = {
@@ -70,6 +71,98 @@ struct efi_capsule_update_info update_info = {
 
 #endif /* EFI_HAVE_CAPSULE_SUPPORT */
 
+/* ========== ECU-150v2: Board ID GPIO Detection ========== */
+#define BOARD_ID_GPIO_1		IMX_GPIO_NR(2, 8)  /* USB1_RSV_ID 4G: 0 / 2G: 0 */
+#define BOARD_ID_GPIO_0		IMX_GPIO_NR(2, 9)  /* USB2_RSV_ID     0 /     1 */
+
+static unsigned long imx8m_gpio_ports[] = {
+	[0] = GPIO1_BASE_ADDR,
+	[1] = GPIO2_BASE_ADDR,
+	[2] = GPIO3_BASE_ADDR,
+	[3] = GPIO4_BASE_ADDR,
+	[4] = GPIO5_BASE_ADDR,
+};
+
+static int gpio_direction_input_legacy(unsigned int gpio)
+{
+	unsigned int port;
+	struct gpio_regs *regs;
+	u32 l;
+
+	port = gpio / 32;
+	gpio &= 0x1f;
+
+	regs = (struct gpio_regs *)imx8m_gpio_ports[port];
+
+	l = readl(&regs->gpio_dir);
+	l &= ~(1 << gpio);
+	writel(l, &regs->gpio_dir);
+
+	return 0;
+}
+
+static int gpio_get_value_legacy(unsigned int gpio)
+{
+	unsigned int port;
+	struct gpio_regs *regs;
+	u32 val;
+
+	port = gpio / 32;
+	gpio &= 0x1f;
+
+	regs = (struct gpio_regs *)imx8m_gpio_ports[port];
+
+	val = (readl(&regs->gpio_dr) >> gpio) & 0x01;
+
+	return val;
+}
+
+int get_board_id(void)
+{
+	int i = 0, value = 0;
+	int baseboard_id;
+	int pin[2];
+
+	pin[0] = BOARD_ID_GPIO_0;
+	pin[1] = BOARD_ID_GPIO_1;
+
+	baseboard_id = 0;
+	for (i = 0; i < 2; i++) {
+		gpio_direction_input_legacy(pin[i]);
+		value = gpio_get_value_legacy(pin[i]);
+		if (value < 0) {
+			printf("Error! Read gpio port: %d failed!\n", pin[i]);
+			return -1;
+		}
+		baseboard_id |= ((value & 0x01) << i);
+	}
+
+	return baseboard_id;
+}
+
+int board_phys_sdram_size(phys_size_t *memsize)
+{
+	u32 board_id;
+
+	board_id = get_board_id();
+	switch (board_id) {
+	case 0: /* 4G */
+		*memsize = 0x100000000;
+		break;
+	case 1: /* 2G */
+		*memsize = 0x80000000;
+		break;
+	case 2: /* 6G */
+		*memsize = 0x180000000;
+		break;
+	default:
+		*memsize = 0x80000000;
+		break;
+	}
+
+	return 0;
+}
+
 int board_early_init_f(void)
 {
 	struct wdog_regs *wdog = (struct wdog_regs *)WDOG1_BASE_ADDR;
@@ -506,6 +599,118 @@ int board_init(void)
 	return 0;
 }
 
+/* ========== ECU-150v2: GPIO Helper ========== */
+static int gpio_set_output(unsigned int gpio, int value)
+{
+	char name[16];
+
+	memset(name, 0, sizeof(name));
+	sprintf(name, "gpio_%d", gpio);
+	gpio_request(gpio, name);
+	gpio_direction_output(gpio, value);
+	gpio_free(gpio);
+
+	return 0;
+}
+
+/* ========== ECU-150v2: Power Sequence ========== */
+#define DEVICE_RESET_DELAY		100 /* 100ms */
+
+#define COM_POWER_EN			IMX_GPIO_NR(5, 1)
+#define M2B_POWER_EN			IMX_GPIO_NR(1, 5)
+#define M2E_POWER_EN			IMX_GPIO_NR(1, 9)
+#define HDMI_POWER_EN			IMX_GPIO_NR(5, 0)
+
+#define NIC0_RESET_GPIO			IMX_GPIO_NR(4, 22)
+#define NIC1_RESET_GPIO			IMX_GPIO_NR(4, 2)
+#define M2B_PERST_GPIO			IMX_GPIO_NR(1, 7)
+#define M2B_RESET_GPIO			IMX_GPIO_NR(4, 29)
+#define M2B_PWR_OFF_GPIO		IMX_GPIO_NR(1, 6)
+#define M2B_W_DISABLE1_GPIO		IMX_GPIO_NR(3, 6)
+#define M2B_W_DISABLE2_GPIO		IMX_GPIO_NR(3, 7)
+
+#define M2E_W_DISABLE1_GPIO		IMX_GPIO_NR(1, 11)
+#define M2E_W_DISABLE2_GPIO		IMX_GPIO_NR(1, 12)
+
+static void system_power_on(void)
+{
+	gpio_set_output(COM_POWER_EN, 1);
+	gpio_set_output(M2B_POWER_EN, 1);
+	gpio_set_output(M2E_POWER_EN, 1);
+	gpio_set_output(HDMI_POWER_EN, 1);
+
+	gpio_set_output(M2E_W_DISABLE1_GPIO, 1);
+	gpio_set_output(M2E_W_DISABLE2_GPIO, 1);
+
+	gpio_set_output(M2B_PWR_OFF_GPIO, 1);
+	gpio_set_output(M2B_W_DISABLE1_GPIO, 1);
+	gpio_set_output(M2B_W_DISABLE2_GPIO, 1);
+
+	mdelay(10);
+}
+
+static void system_reset_gpio(void)
+{
+	gpio_set_output(M2B_PERST_GPIO, 0);
+	gpio_set_output(M2B_RESET_GPIO, 0);
+
+	mdelay(DEVICE_RESET_DELAY);
+
+	gpio_set_output(M2B_PERST_GPIO, 1);
+	gpio_set_output(M2B_RESET_GPIO, 1);
+}
+
+/* ========== ECU-150v2: EEPROM MAC Address ========== */
+static int ecu_setup_mac_from_eeprom(void)
+{
+	struct udevice *bus, *chip;
+	u8 mac[6];
+	int ret, fail = 0;
+
+	ret = uclass_get_device_by_seq(UCLASS_I2C, EEPROM_I2C_BUS, &bus);
+	if (ret) {
+		printf("ECU-150v2: EEPROM I2C bus %d not found (err %d)\n",
+		       EEPROM_I2C_BUS, ret);
+		return ret;
+	}
+	ret = i2c_get_chip(bus, EEPROM_I2C_ADDR, 1, &chip);
+	if (ret) {
+		printf("ECU-150v2: EEPROM chip 0x%02x not found (err %d)\n",
+		       EEPROM_I2C_ADDR, ret);
+		return ret;
+	}
+
+	/* eth0 (eQOS) */
+	ret = dm_i2c_read(chip, EEPROM_MAC_OFFSET_ETH0, mac, EEPROM_MAC_LENGTH);
+	if (ret) {
+		printf("ECU-150v2: EEPROM read eth0 MAC @0x%02x failed (err %d)\n",
+		       EEPROM_MAC_OFFSET_ETH0, ret);
+		fail++;
+	} else if (!is_valid_ethaddr(mac)) {
+		printf("ECU-150v2: EEPROM eth0 MAC invalid (%pM), need to burn\n",
+		       mac);
+		fail++;
+	} else {
+		eth_env_set_enetaddr("ethaddr", mac);
+	}
+
+	/* eth1 (FEC) */
+	ret = dm_i2c_read(chip, EEPROM_MAC_OFFSET_ETH1, mac, EEPROM_MAC_LENGTH);
+	if (ret) {
+		printf("ECU-150v2: EEPROM read eth1 MAC @0x%02x failed (err %d)\n",
+		       EEPROM_MAC_OFFSET_ETH1, ret);
+		fail++;
+	} else if (!is_valid_ethaddr(mac)) {
+		printf("ECU-150v2: EEPROM eth1 MAC invalid (%pM), need to burn\n",
+		       mac);
+		fail++;
+	} else {
+		eth_env_set_enetaddr("eth1addr", mac);
+	}
+
+	return fail ? -EINVAL : 0;
+}
+
 int board_late_init(void)
 {
 #if CONFIG_IS_ENABLED(ENV_IS_IN_MMC)
@@ -513,10 +718,18 @@ int board_late_init(void)
 #endif
 
 #ifdef CONFIG_ENV_VARS_UBOOT_RUNTIME_CONFIG
-	env_set("board_name", "EVK");
+	env_set("board_name", "ECU150V2");
 	env_set("board_rev", "iMX8MP");
 #endif
 
+	if (ecu_setup_mac_from_eeprom())
+		puts("ECU-150v2: WARNING - using random MAC, please burn EEPROM\n");
+	system_power_on();
+	system_reset_gpio();
+
+	puts("DeviceName is ECU150V2.\n");
+	env_set("devicename", "ecu150v2");
+
 	return 0;
 }
 
