From 374e8fd76b011784a75f9c877a76f340cedcb1a0 Mon Sep 17 00:00:00 2001
From: "suricata.lu" <suricata.lu@gmail.com>
Date: Mon, 20 Apr 2026 17:54:09 +0800
Subject: [PATCH 2/3] Upstream driver code modifications

Upstream-Status: Inappropriate [embedded board port]
---
 drivers/net/ethernet/freescale/fec_main.c     | 22 +++++++++++++++++++
 .../net/ethernet/stmicro/stmmac/stmmac_main.c | 22 +++++++++++++++++++
 drivers/net/phy/dp83867.c                     |  5 +++++
 3 files changed, 49 insertions(+)

diff --git a/drivers/net/ethernet/freescale/fec_main.c b/drivers/net/ethernet/freescale/fec_main.c
index 811a66062d32..884be9524e4c 100644
--- a/drivers/net/ethernet/freescale/fec_main.c
+++ b/drivers/net/ethernet/freescale/fec_main.c
@@ -312,6 +312,24 @@ MODULE_PARM_DESC(macaddr, "FEC Ethernet MAC address");
 
 static int mii_cnt;
 
+static void adv_force_eth_name_by_alias(struct device *dev,
+					struct device_node *np,
+					struct net_device *ndev)
+{
+	int id;
+
+	/* DT: /aliases { ethernet0 = &fec; ethernet1 = &eqos; }; */
+	id = of_alias_get_id(np, "ethernet");
+	if (id < 0)
+		return;
+
+	if (id == 0 || id == 1) {
+		snprintf(ndev->name, IFNAMSIZ, "eth%d", id);
+		dev_info(dev, "force netdev name to %s by DT alias ethernet%d\n",
+			 ndev->name, id);
+	}
+}
+
 static struct bufdesc *fec_enet_get_nextdesc(struct bufdesc *bdp,
 					     struct bufdesc_prop *bd)
 {
@@ -4599,6 +4617,10 @@ fec_probe(struct platform_device *pdev)
 
 	ndev->max_mtu = PKT_MAXBUF_SIZE - ETH_HLEN - ETH_FCS_LEN;
 
+#if defined(CONFIG_ADV_BOARD)
+	adv_force_eth_name_by_alias(&pdev->dev, pdev->dev.of_node, ndev);
+#endif
+
 	ret = register_netdev(ndev);
 	if (ret)
 		goto failed_register;
diff --git a/drivers/net/ethernet/stmicro/stmmac/stmmac_main.c b/drivers/net/ethernet/stmicro/stmmac/stmmac_main.c
index fd1644c91eb2..53ae2919280d 100644
--- a/drivers/net/ethernet/stmicro/stmmac/stmmac_main.c
+++ b/drivers/net/ethernet/stmicro/stmmac/stmmac_main.c
@@ -7525,6 +7525,24 @@ static const struct xdp_metadata_ops stmmac_xdp_metadata_ops = {
 	.xmo_rx_timestamp		= stmmac_xdp_rx_timestamp,
 };
 
+static void adv_force_eth_name_by_alias(struct device *dev,
+					struct device_node *np,
+					struct net_device *ndev)
+{
+	int id;
+
+	/* DT: /aliases { ethernet0 = &fec; ethernet1 = &eqos; }; */
+	id = of_alias_get_id(np, "ethernet");
+	if (id < 0)
+		return;
+
+	if (id == 0 || id == 1) {
+		snprintf(ndev->name, IFNAMSIZ, "eth%d", id);
+		dev_info(dev, "force netdev name to %s by DT alias ethernet%d\n",
+			 ndev->name, id);
+	}
+}
+
 /**
  * stmmac_dvr_probe
  * @device: device pointer
@@ -7819,6 +7837,10 @@ int stmmac_dvr_probe(struct device *device,
 		goto error_phy_setup;
 	}
 
+#if defined(CONFIG_ADV_BOARD)
+	adv_force_eth_name_by_alias(device, device->of_node, ndev);
+#endif
+
 	ret = register_netdev(ndev);
 	if (ret) {
 		dev_err(priv->device, "%s: ERROR %i registering the device\n",
diff --git a/drivers/net/phy/dp83867.c b/drivers/net/phy/dp83867.c
index 4120385c5a79..788b167d0a67 100644
--- a/drivers/net/phy/dp83867.c
+++ b/drivers/net/phy/dp83867.c
@@ -835,6 +835,11 @@ static int dp83867_config_init(struct phy_device *phydev)
 		ret = phy_write(phydev, MII_DP83867_PHYCTRL, val);
 		if (ret)
 			return ret;
+#if defined(CONFIG_ADV_BOARD)
+		ret = phy_write(phydev, DP83867_LEDCR1, 0x6B58);
+		if (ret)
+			return ret;
+#endif
 
 		/* If rgmii mode with no internal delay is selected, we do NOT use
 		 * aligned mode as one might expect.  Instead we use the PHY's default
-- 
