#!/bin/sh
# overlay-init - initramfs /init that builds an overlayfs root.
#
# Mountpoint layout (standard lower/upper/work/merged names, under /run/):
#   /run/rootfs/lower    real rootfs, read-only          (lowerdir)
#   /run/rootfs/merged   combined view, switch_root here (the new /)
#   /run/rwdata          writable storage: tmpfs or a real partition
#     <slot>/upper       all writes land here            (upperdir)
#     <slot>/work        overlayfs internal scratch      (workdir)
#
# Boot flow:
#   kernel -> unpack initramfs -> /init (this script, PID 1)
#     -> mount real rootfs read-only as lower
#     -> mount tmpfs (or overlayrwdev) for upper/work
#     -> mount overlayfs as merged
#     -> switch_root (frees ALL initramfs RAM) -> real init
#
# Recognized kernel cmdline parameters:
#   root=DEV               read-only rootfs device, the lower layer (required)
#                          /dev/..., or UUID= / LABEL= (needs findfs)
#   rootfstype=TYPE        lower filesystem type      (default: ext4)
#   rootdelay=SECS         max wait for root device   (default: 10)
#   init=PATH              real init to hand off to   (default: /sbin/init)
#   overlayrwdev=DEV       persistent device for upper/work
#                          (default: unset -> tmpfs, volatile, wiped on reboot)
#   overlayslot=NAME       writable subdir under /run/rwdata (A/B separation)
#                          (default: derived from root=, else "single")
#   overlayroot=disabled   skip overlay, boot real rootfs read-write
#                          (development backdoor)

log() { echo "overlay-init: $*"; }

rescue() {
    echo "overlay-init: FATAL: $*" >&2
    echo "overlay-init: dropping to rescue shell" >&2
    exec /bin/sh
}

# --- 1. kernel virtual filesystems ------------------------------------
# NOTE: even with CONFIG_DEVTMPFS_MOUNT=y the kernel does NOT auto-mount
# devtmpfs inside an initramfs - we must do it ourselves.
mount -t proc     proc     /proc || rescue "cannot mount /proc"
mount -t sysfs    sysfs    /sys  || rescue "cannot mount /sys"
mount -t devtmpfs devtmpfs /dev  || rescue "cannot mount /dev"

# --- 2. parse kernel command line --------------------------------------
ROOT=""
FSTYPE="ext4"
DELAY=10
REAL_INIT="/sbin/init"
RWDEV=""
SLOT=""
OVERLAY="enabled"

for arg in $(cat /proc/cmdline); do
    case "$arg" in
        root=*)         ROOT="${arg#root=}" ;;
        rootfstype=*)   FSTYPE="${arg#rootfstype=}" ;;
        rootdelay=*)    DELAY="${arg#rootdelay=}" ;;
        init=*)         REAL_INIT="${arg#init=}" ;;
        overlayrwdev=*) RWDEV="${arg#overlayrwdev=}" ;;
        overlayslot=*)  SLOT="${arg#overlayslot=}" ;;
        overlayroot=*)  OVERLAY="${arg#overlayroot=}" ;;
    esac
done

[ -n "$ROOT" ] || rescue "root= not found in cmdline"

# --- 3. wait for the root device (replaces kernel's rootwait) ----------
resolve_root() {
    case "$ROOT" in
        UUID=*|LABEL=*|PARTUUID=*|PARTLABEL=*)
            findfs "$ROOT" 2>/dev/null ;;          # needs busybox findfs
        *)  echo "$ROOT" ;;
    esac
}

DEV=""
i=0
while [ "$i" -lt $((DELAY * 10)) ]; do
    DEV="$(resolve_root)"
    [ -n "$DEV" ] && [ -b "$DEV" ] && break
    sleep 0.1
    i=$((i + 1))
done
[ -n "$DEV" ] && [ -b "$DEV" ] || rescue "root device '$ROOT' not found after ${DELAY}s"
log "lower (read-only rootfs): $DEV ($FSTYPE)"

# --- 4. development backdoor: overlayroot=disabled ----------------------
if [ "$OVERLAY" = "disabled" ]; then
    log "overlay DISABLED via cmdline - booting real rootfs read-write"
    mkdir -p /run/rootfs/merged
    mount -t "$FSTYPE" -o rw "$DEV" /run/rootfs/merged || rescue "cannot mount $DEV rw"
    mount --move /proc /run/rootfs/merged/proc 2>/dev/null
    mount --move /sys  /run/rootfs/merged/sys  2>/dev/null
    mount --move /dev  /run/rootfs/merged/dev  2>/dev/null
    exec switch_root /run/rootfs/merged "$REAL_INIT"
    rescue "switch_root failed"
fi

# --- 5. pick the writable slot -----------------------------------------
# RAUC-neutral: this only answers "which writable subdir to use". RAUC (if
# present) just changes root= in U-Boot; nothing here knows about RAUC.
if [ -z "$SLOT" ]; then
    if [ -n "$RWDEV" ]; then
        case "$DEV" in
            *p2) SLOT="slot-a" ;;   # adjust to match your A/B partition map
            *p3) SLOT="slot-b" ;;
            *)   SLOT="single" ;;
        esac
    else
        SLOT="single"             # volatile tmpfs: nothing to separate
    fi
fi
log "writable slot: $SLOT"

# --- 6. mount the layers ------------------------------------------------
# overlayfs must be available (built-in or module shipped in initramfs)
modprobe overlay 2>/dev/null
grep -qw overlay /proc/filesystems || rescue "kernel lacks overlayfs support"

mkdir -p /run/rootfs/lower /run/rootfs/merged /run/rwdata

# lower: the real rootfs, mounted read-only - never written again
mount -t "$FSTYPE" -o ro "$DEV" /run/rootfs/lower || rescue "cannot mount $DEV ro"

# writable storage for upper/work:
#   - overlayrwdev= given -> persistent partition (survives reboot)
#   - otherwise           -> tmpfs in RAM (volatile, wiped on reboot)
if [ -n "$RWDEV" ]; then
    mount "$RWDEV" /run/rwdata || rescue "cannot mount rw device $RWDEV"
    log "upper/work on persistent device: $RWDEV"
else
    mount -t tmpfs -o mode=0755 tmpfs /run/rwdata || rescue "cannot mount tmpfs"
    log "upper/work on volatile tmpfs"
fi
mkdir -p "/run/rwdata/$SLOT/upper" "/run/rwdata/$SLOT/work"

# merged: what the system will see as /
mount -t overlay overlay \
    -o lowerdir=/run/rootfs/lower,upperdir=/run/rwdata/$SLOT/upper,workdir=/run/rwdata/$SLOT/work \
    /run/rootfs/merged || rescue "cannot mount overlayfs"

# --- 7. prepare the merged root -----------------------------------------
MERGED=/run/rootfs/merged

# Drop the root entry from fstab so the real init does not try to remount /
# from the block device. Overlay copy only - on-disk fstab kept intact.
if [ -f /run/rootfs/lower/etc/fstab ]; then
    awk '$1 ~ /^#/ || $2 != "/"' /run/rootfs/lower/etc/fstab > "$MERGED/etc/fstab"
    echo "# root entry removed by overlay-init (overlay root active)" \
        >> "$MERGED/etc/fstab"
fi

# Keep the layers reachable from inside the new root (debug / OTA access).
# Use root-level /ro and /rw so systemd's tmpfs on /run does not shadow them.
mkdir -p "$MERGED/ro" "$MERGED/rw"
mount --move /run/rootfs/lower "$MERGED/ro" || rescue "cannot move lower to /ro"
mount --move /run/rwdata       "$MERGED/rw" || rescue "cannot move rwdata to /rw"

# --- 8. hand off --------------------------------------------------------
# busybox switch_root does not move API filesystems for us (util-linux does)
mount --move /proc "$MERGED/proc" 2>/dev/null
mount --move /sys  "$MERGED/sys"  2>/dev/null
mount --move /dev  "$MERGED/dev"  2>/dev/null

log "switching to overlay root, real init: $REAL_INIT"
exec switch_root "$MERGED" "$REAL_INIT"
rescue "switch_root failed"
